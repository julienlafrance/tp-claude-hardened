# =============================================================================
#  .secret/litellm.env.example — modèle de config backend LiteLLM.
# -----------------------------------------------------------------------------
#  COPIER en .secret/litellm.env (GITIGNORÉ) puis renseigner la virtual key :
#      cp .secret/litellm.env.example .secret/litellm.env
#  Chargé automatiquement (export) par lib/log.sh -> vu par tous les steps.
# =============================================================================

# Virtual key LiteLLM SCOPÉE (auth de l'agent). SEUL vrai secret ici.
# Fournie par la gateway LiteLLM sur ixia — JAMAIS la master key.
LITELLM_VIRTUAL_KEY=sk-litellm-SCOPED-KEY-a-remplacer

# Endpoint modèle (optionnel). Par défaut, le durci utilise la passerelle FIGÉE
# tp_internal 172.31.7.1:3101 (device Incus litellm -> ixia). Décommenter pour forcer.
#LITELLM_ENDPOINT=http://172.31.7.1:3101

# Modèle Claude routé par LiteLLM (quand la route Anthropic existe côté ixia).
# Par défaut = modèle Ollama local. Renseigner le nom exact du modèle Claude si routé.
ANTHROPIC_MODEL=qwen2.5-coder:14b
ANTHROPIC_SMALL_FAST_MODEL=qwen3:0.6b
